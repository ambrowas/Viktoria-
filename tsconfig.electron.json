{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",            // ✅ output CJS
    "moduleResolution": "Node",
    "outDir": "dist-electron",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node", "electron"]
  },
  "include": ["main.ts", "preload.ts"],
  "exclude": ["src", "node_modules", "dist"]
}

{
  "name": "viktoria-gameshow",
  "version": "1.0.0",
  "description": "Viktoria, The GameShow - Create and manage your own game shows.",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"npm run dev:electron\"",
    "dev:electron": "npm run prepare:electron && tsc --project tsconfig.electron.json --watch & wait-on http://localhost:5173 && electron dist-electron/main.js",
    "build": "vite build && npm run build:electron",
    "build:electron": "npm run prepare:electron && tsc --project tsconfig.electron.json",
    "prepare:electron": "mkdir -p dist-electron && echo '{\"type\":\"commonjs\"}' > dist-electron/package.json",
    "start": "npm run build && electron dist-electron/main.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@hello-pangea/dnd": "^16.4.0",
    "canvas-confetti": "^1.9.3",
    "dotenv": "^16.6.1",
    "firebase": "^10.12.2",
    "framer-motion": "^12.23.22",
    "lottie-react": "^2.4.1",
    "lucide-react": "^0.544.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-tsparticles": "^2.12.2",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^24.7.1",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.0.3",
    "concurrently": "^8.2.2",
    "electron": "^38.1.2",
    "tailwindcss": "^3.4.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2",
    "vite": "^7.1.6",
    "wait-on": "^9.0.0"
  }
}
